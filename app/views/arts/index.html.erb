<% content_for :title, "Arts" %>
<div class="w-full min-h-[50vh]">
  <div id="arts" class="min-w-full  space-y-5">
    <% if @arts.any? %>
      <% @arts.each do |art| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0 my-32">
          <%= render art %>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No art found.</p>
    <% end %>
  </div>
  <%# Note the double equals sign "==" which marks the output as trusted and html safe: %>
</div>

<section data-controller="carousel"
         class="relative w-full max-w-4xl mx-auto"
         data-action="mouseenter->carousel#pauseAutoPlay mouseleave->carousel#resumeAutoPlay">
  <!-- Carousel wrapper -->
  <div class="relative h-[800px] overflow-hidden rounded-lg bg-gray-100" data-carousel-target="container">
    <% if HomePage.last.images.any? %>
      <% HomePage.last.images.each_with_index do |image, index| %>
        <div class="carousel-slide duration-700 ease-in-out absolute inset-0 transition-transform transform <%= index == 0 ? 'translate-x-0' : 'translate-x-full' %>"
           data-carousel-target="slide"
           data-slide-index="<%= index %>">
          <%= image_tag image, class: "w-full h-full object-cover", alt: "Carousel image #{index + 1}" %>
        </div>
      <% end %>
    <% end %>
  </div>
  <!-- Previous button -->
  <button type="button"
          class="absolute top-0 left-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none"
          data-action="click->carousel#previous"
    data-carousel-target="prevButton">
    <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 group-hover:bg-white/50 group-focus:ring-4 group-focus:ring-white group-focus:outline-none">
      <svg class="w-4 h-4 text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 1 1 5l4 4"/>
      </svg>
      <span class="sr-only">Previous</span>
    </span>
  </button>
  <!-- Next button -->
  <button type="button"
          class="absolute top-0 right-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none"
          data-action="click->carousel#next"
    data-carousel-target="nextButton">
    <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 group-hover:bg-white/50 group-focus:ring-4 group-focus:ring-white group-focus:outline-none">
      <svg class="w-4 h-4 text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
      </svg>
      <span class="sr-only">Next</span>
    </span>
  </button>
  <!-- Indicators -->
  <div class="absolute z-30 flex space-x-3 -translate-x-1/2 bottom-5 left-1/2" data-carousel-target="indicators">
    <% HomePage.last.images.each_with_index do |image, index| %>
      <button type="button"
              class="w-3 h-3 rounded-full <%= index == 0 ? 'bg-white' : 'bg-white/50' %> hover:bg-white transition-colors duration-200"
              data-action="click->carousel#goToSlide"
        data-slide-index="<%= index %>"
        data-carousel-target="indicator"
        aria-current="<%= index == 0 ? 'true' : 'false' %>"
        aria-label="Slide <%= index + 1 %>">
      </button>
    <% end %>
  </div>
</section>

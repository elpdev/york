<div class="dashboard-container">
  <div class="dashboard-header">
    <h1 class="dashboard-title">Dashboard</h1>
    <p class="dashboard-subtitle">
      Welcome to your art portfolio admin dashboard. Here's an overview of your site.
    </p>
  </div>

  <!-- Statistics Cards -->
  <div class="stats-grid">
    <!-- Art Pieces Card -->
    <div class="stat-card">
      <div class="stat-card-content">
        <div class="stat-icon">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M7.5 18 18 7.5M3 16.5v5.25A2.25 2.25 0 0 0 5.25 24h13.5A2.25 2.25 0 0 0 21 21.75V16.5" />
          </svg>
        </div>
        <div class="stat-info">
          <p class="stat-label">Art Pieces</p>
          <p class="stat-value"><%= Art.count %></p>
        </div>
      </div>
    </div>

    <!-- Contact Messages Card -->
    <div class="stat-card">
      <div class="stat-card-content">
        <div class="stat-icon">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 21.75 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
        <div class="stat-info">
          <p class="stat-label">Contact Messages</p>
          <p class="stat-value"><%= Contact.count %></p>
        </div>
      </div>
    </div>

    <!-- Users Card -->
    <div class="stat-card">
      <div class="stat-card-content">
        <div class="stat-icon">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
        </div>
        <div class="stat-info">
          <p class="stat-label">Admin Users</p>
          <p class="stat-value"><%= User.where(admin: true).count %></p>
        </div>
      </div>
    </div>

    <!-- Active Sessions Card -->
    <div class="stat-card">
      <div class="stat-card-content">
        <div class="stat-icon">
          <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.348 14.652a3.75 3.75 0 0 1 0-5.304m5.304 0a3.75 3.75 0 0 1 0 5.304m-7.425 2.121a6.75 6.75 0 0 1 0-9.546m9.546 0a6.75 6.75 0 0 1 0 9.546M5.106 18.894c-3.808-3.807-3.808-9.98 0-13.788 3.807-3.808 9.98-3.808 13.788 0 3.808 3.807 3.808 9.98 0 13.788-3.807 3.808-9.98 3.808-13.788 0Z" />
          </svg>
        </div>
        <div class="stat-info">
          <p class="stat-label">Active Sessions</p>
          <p class="stat-value"><%= Session.count %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="quick-actions">
    <div class="quick-actions-content">
      <h3 class="quick-actions-title">Quick Actions</h3>
      <div class="quick-actions-grid">
        <%= link_to "Add New Art Piece", new_madmin_art_path, class: "btn-primary" %>
        <%= link_to "View Contacts", madmin_contacts_path, class: "btn-secondary" %>
        <%= link_to "Manage Home Page", madmin_home_pages_path, class: "btn-secondary" %>
      </div>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="activity-grid">
    <!-- Recent Contact Messages -->
    <div class="activity-card">
      <div class="activity-header">
        <h3 class="activity-title">Recent Contact Messages</h3>
        <p class="activity-subtitle">Latest messages from visitors</p>
      </div>
      <div class="activity-content">
        <% recent_contacts = Contact.order(created_at: :desc).limit(5) %>
        <% if recent_contacts.any? %>
          <ul class="activity-list">
            <% recent_contacts.each do |contact| %>
              <li class="activity-item">
                <div class="contact-item-header">
                  <div class="contact-item-info">
                    <div class="contact-status-dot">
                      <div class="status-dot"></div>
                    </div>
                    <div class="contact-details">
                      <p class="contact-name"><%= contact.name %></p>
                      <p class="contact-email"><%= contact.email %></p>
                    </div>
                  </div>
                  <div class="contact-time">
                    <%= time_ago_in_words(contact.created_at) %> ago
                  </div>
                </div>
                <div>
                  <p class="contact-message">
                    <%= truncate(contact.body, length: 100) %>
                  </p>
                </div>
              </li>
            <% end %>
          </ul>
          <div class="activity-footer">
            <%= link_to "View all contacts", madmin_contacts_path, class: "link-primary" %>
          </div>
        <% else %>
          <div class="empty-state">
            <p class="empty-text">No contact messages yet.</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Art Pieces -->
    <div class="activity-card">
      <div class="activity-header">
        <h3 class="activity-title">Recent Art Pieces</h3>
        <p class="activity-subtitle">Latest additions to your portfolio</p>
      </div>
      <div class="activity-content">
        <% recent_art = Art.order(created_at: :desc).limit(5) %>
        <% if recent_art.any? %>
          <ul class="activity-list">
            <% recent_art.each do |art| %>
              <li class="activity-item">
                <div class="art-item">
                  <div class="art-thumbnail">
                    <% if art.image.attached? %>
                      <%= image_tag art.image, class: "art-image" %>
                    <% else %>
                      <div class="art-placeholder">
                        <svg fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                        </svg>
                      </div>
                    <% end %>
                  </div>
                  <div class="art-info">
                    <p class="art-name"><%= art.name %></p>
                    <p class="art-time"><%= time_ago_in_words(art.created_at) %> ago</p>
                  </div>
                  <div class="art-action">
                    <%= link_to "Edit", edit_madmin_art_path(art), class: "link-primary" %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
          <div class="activity-footer">
            <%= link_to "View all art pieces", madmin_arts_path, class: "link-primary" %>
          </div>
        <% else %>
          <div class="empty-state">
            <p class="empty-text">No art pieces added yet.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>